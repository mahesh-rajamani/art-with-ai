# ── Replicate (Flux) — always server-side, never exposed to browser ──
REPLICATE_KEY=r8_your_token_here

# ── Google Image API feature flag ──
# Set to "true" to show the settings icon and allow users to enter their own Google token
# Set to "false" (or omit) to use Flux/Replicate only
ENABLE_GOOGLE_IMAGE_API=false

# ── Cloudinary (optional, for permanent image storage) ──
CLOUDINARY_NAME=your_cloud_name
CLOUDINARY_PRESET=your_upload_preset

# ── AstraDB (optional, for gallery persistence) ──
ASTRA_DB_ENDPOINT=https://xxx-region.apps.astra.datastax.com
ASTRA_DB_TOKEN=AstraCS:your_token
ASTRA_DB_KEYSPACE=iags
